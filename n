import chess
import math
import time
import random

class MiniChessEngine:
    def __init__(self, depth=3):
        self.depth = depth
        self.nodes_explored = 0

        # Base material values
        self.piece_values = {
            chess.PAWN: 1,
            chess.KNIGHT: 3,
            chess.BISHOP: 3,
            chess.ROOK: 5,
            chess.QUEEN: 9,
            chess.KING: 1000 # Very large value
        }

        self.center_squares = {chess.D4, chess.E4, chess.D5, chess.E5}

    def evaluate_board(self, board):
        """
        Calculates the static evaluation of the board.
        Positive scores favor White (Max), Negative scores favor Black (Min).
        """
        # Terminal states
        if board.is_checkmate():
            return -9999 if board.turn == chess.WHITE else 9999
        if board.is_stalemate() or board.is_insufficient_material():
            return 0

        score = 0.0

        # 1. Material & Positional Evaluation
        for square in chess.SQUARES:
            piece = board.piece_at(square)
            if piece:
                val = self.piece_values[piece.piece_type]

                if square in self.center_squares:
                    val += 0.2

                if piece.piece_type == chess.KING and square in self.center_squares:
                    val -= 0.5

                score += val if piece.color == chess.WHITE else -val

        # 2. Piece Mobility (Bonus for having more legal moves)
        mobility_bonus = len(list(board.legal_moves)) * 0.02
        score += mobility_bonus if board.turn == chess.WHITE else -mobility_bonus

        return score

    def order_moves(self, board):
        """Orders moves to maximize Alpha-Beta pruning efficiency."""
        moves = list(board.legal_moves)

        def move_score(move):
            score = 0
            if board.is_capture(move): score += 10
            if board.gives_check(move): score += 5
            if board.is_promotion(move): score += 8
            return score

        moves.sort(key=move_score, reverse=True)
        return moves

    def alpha_beta(self, board, depth, alpha, beta, is_max):
        self.nodes_explored += 1

        if depth == 0 or board.is_game_over():
            return self.evaluate_board(board)

        moves = self.order_moves(board)

        if is_max: # White's turn
            max_eval = -math.inf
            for move in moves:
                board.push(move)
                eval_val = self.alpha_beta(board, depth - 1, alpha, beta, False)
                board.pop()
                max_eval = max(max_eval, eval_val)
                alpha = max(alpha, eval_val)
                if beta <= alpha:
                    break # Beta cutoff
            return max_eval
        else: # Black's turn (AI)
            min_eval = math.inf
            for move in moves:
                board.push(move)
                eval_val = self.alpha_beta(board, depth - 1, alpha, beta, True)
                board.pop()
                min_eval = min(min_eval, eval_val)
                beta = min(beta, min_eval)
                if beta <= alpha:
                    break # Alpha cutoff
            return min_eval

    def get_best_move(self, board):
        """Returns the best move, the evaluation score, nodes explored, and time taken."""
        self.nodes_explored = 0
        start_time = time.time()

        best_move = None
        is_max = board.turn == chess.WHITE

        best_val = -math.inf if is_max else math.inf
        alpha = -math.inf
        beta = math.inf

        for move in self.order_moves(board):
            board.push(move)
            board_val = self.alpha_beta(board, self.depth - 1, alpha, beta, not is_max)
            board.pop()

            if is_max:
                if board_val > best_val:
                    best_val = board_val
                    best_move = move
                alpha = max(alpha, best_val)
            else:
                if board_val < best_val:
                    best_val = board_val
                    best_move = move
                beta = min(beta, best_val)

        decision_time = time.time() - start_time
        return best_move, best_val, self.nodes_explored, decision_time

def run_ai_vs_random_tournament(games=5):
    print(f"--- Starting {games}-Game Tournament: Random (White) vs AI (Black) ---")
    engine = MiniChessEngine(depth=3)

    results = {'AI_Wins': 0, 'Random_Wins': 0, 'Draws': 0}
    total_nodes = 0
    total_time = 0
    total_ai_moves = 0

    for i in range(games):
        board = chess.Board()
        print(f"\nGame {i+1} starting...")

        while not board.is_game_over():
            if board.turn == chess.WHITE:
                # Random bot plays White
                move = random.choice(list(board.legal_moves))
                board.push(move)
            else:
                # Engine plays Black
                move, score, nodes, time_taken = engine.get_best_move(board)
                board.push(move)

                total_nodes += nodes
                total_time += time_taken
                total_ai_moves += 1

        # Game over logic
        result = board.result()
        if result == "1-0":
            results['Random_Wins'] += 1
            print("Winner: Random (White)")
        elif result == "0-1":
            results['AI_Wins'] += 1
            print("Winner: AI (Black)")
        else:
            results['Draws'] += 1
            print("Result: Draw")

    print("\n--- Tournament Results ---")
    print(f"Record (AI Wins - Random Wins - Draws): {results['AI_Wins']} - {results['Random_Wins']} - {results['Draws']}")
    if total_ai_moves > 0:
        print(f"Average Nodes Explored Per AI Move: {total_nodes // total_ai_moves}")
        print(f"Average Time Per AI Move: {total_time / total_ai_moves:.3f} seconds")

def play_human_vs_ai():
    board = chess.Board()
    engine = MiniChessEngine(depth=3)

    print("\n--- Human (White) vs AI (Black) ---")
    print("Enter moves in UCI format (e.g., 'e2e4', 'g1f3'). Type 'quit' to exit.")

    while not board.is_game_over():
        print(f"\n{board}")
        if board.turn == chess.WHITE:
            human_move = input("\nYour move: ")
            if human_move.lower() == 'quit':
                break
            try:
                move = chess.Move.from_uci(human_move)
                if move in board.legal_moves:
                    board.push(move)
                else:
                    print("Illegal move. Try again.")
            except ValueError:
                print("Invalid format. Use UCI format like 'e2e4'.")
        else:
            print("\nAI is thinking...")
            move, score, nodes, time_taken = engine.get_best_move(board)
            print(f"AI chose: {move} | Eval Score: {score:.2f} | Nodes Explored: {nodes} | Time: {time_taken:.2f}s")
            board.push(move)

    print("\nGame Over!")
    print("Result:", board.result())

