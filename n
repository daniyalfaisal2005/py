import math

def heuristic(state):
    return (2 * state['health']) - (8 * state['intrusion']) - (5 * state['vulns']) + (3 * state['resources'])

def simulate_action(state, action, is_defender):

    new_state = state.copy()
    if action == 'patch': new_state['vulns'] = max(0, new_state['vulns'] - 2)

    return new_state

def cyber_minimax(state, depth, is_defender):
    if depth == 0 or state['health'] <= 0:
        return heuristic(state)

    legal_actions = ['attack', 'patch', 'isolate', 'scan']

    if is_defender:
        best_val = -math.inf
        for action in legal_actions:
            new_state = simulate_action(state, action, True)
            eval_val = cyber_minimax(new_state, depth - 1, False)
            best_val = max(best_val, eval_val)
        return best_val
    else:
        best_val = math.inf
        for action in legal_actions:
            new_state = simulate_action(state, action, False)
            eval_val = cyber_minimax(new_state, depth - 1, True)
            best_val = min(best_val, eval_val)
        return best_val

