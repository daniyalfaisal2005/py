import math

class CoinAnalyzer:
    def __init__(self):
        self.nodes_explored = 0

    def minimax(self, coins, is_max):
        self.nodes_explored += 1
        if not coins: return 0
        if len(coins) == 1: return coins[0] if is_max else -coins[0]

        if is_max:
            left_pick = coins[0] + self.minimax(coins[1:], False)
            right_pick = coins[-1] + self.minimax(coins[:-1], False)
            return max(left_pick, right_pick)
        else:
            left_pick = -coins[0] + self.minimax(coins[1:], True)
            right_pick = -coins[-1] + self.minimax(coins[:-1], True)
            return min(left_pick, right_pick)

    def alpha_beta(self, coins, alpha, beta, is_max, depth=0):
        self.nodes_explored += 1
        if not coins: return 0
        if len(coins) == 1: return coins[0] if is_max else -coins[0]

        if is_max:
            max_eval = -math.inf
            # Pick Left
            eval_left = coins[0] + self.alpha_beta(coins[1:], alpha, beta, False, depth + 1)
            max_eval = max(max_eval, eval_left)
            alpha = max(alpha, max_eval)
            if beta <= alpha:
                print(f"Pruning at depth {depth}: alpha={alpha}, beta={beta}")
                return max_eval

            # Pick Right
            eval_right = coins[-1] + self.alpha_beta(coins[:-1], alpha, beta, False, depth + 1)
            max_eval = max(max_eval, eval_right)
            return max_eval
        else:

            min_eval = math.inf
            eval_left = -coins[0] + self.alpha_beta(coins[1:], alpha, beta, True, depth + 1)
            min_eval = min(min_eval, eval_left)
            beta = min(beta, min_eval)
            if beta <= alpha:
                print(f"Pruning at depth {depth}: alpha={alpha}, beta={beta}")
                return min_eval

            eval_right = -coins[-1] + self.alpha_beta(coins[:-1], alpha, beta, True, depth + 1)
            min_eval = min(min_eval, eval_right)
            return min_eval

